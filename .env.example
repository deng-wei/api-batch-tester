# ============================================================
# API 密钥配置文件示例
# ============================================================
# 使用说明：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 填入实际的 API Key 和 Base URL
#   3. 在 YAML 配置中通过 ${变量名} 引用，例如 api_key: "${DEERAPI_KEY}"
#
# 注意：.env 文件已被 .gitignore 忽略，不会提交到版本库
# ============================================================

# ---------- DeerAPI ----------
DEERAPI_KEY=sk-your-deerapi-key-here
DEERAPI_BASE_URL=https://api.deerapi.com/v1

# ---------- 示例：其他 API 提供商 ----------
# OPENAI_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# VOLCENGINE_KEY=your-volcengine-key-here
# VOLCENGINE_BASE_URL=https://visual.volcengineapi.com
